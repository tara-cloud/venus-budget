# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://budget_user:budget_pass@localhost:5432/budget_app?schema=public"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# URL of your deployment (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# Secret key — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-in-production-min-32-chars"

# ── Production Docker ─────────────────────────────────────────────────────────
# PostgreSQL credentials (override defaults)
POSTGRES_DB=budget_app
POSTGRES_USER=budget_user
POSTGRES_PASSWORD=change_me_in_production

# App port (default: 3000)
APP_PORT=3000

# App version (used in docker image tag)
APP_VERSION=1.1.0

# Data mount path — where PostgreSQL + app data is stored on the host
# For CasaOS: set to your CasaOS DATA path, e.g. /DATA/AppData/venus-budget
DATA_PATH=./data

# Plaid (optional — for bank integration)
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"
